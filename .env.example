# ============================================================
# FRONTEND - Variables de Entorno
# ============================================================
# COPIAR este archivo a .env.local y llenar con valores reales

# ============================================================
# API GATEWAY (Backend)
# ============================================================
# URL del API Gateway (servidor Express)
# Desarrollo: http://localhost:3001/api
# Producción: https://api.tudominio.com/api
VITE_API_BASE_URL=http://localhost:3001/api

# ============================================================
# SUPABASE (Opcional - solo si usas direct access)
# ============================================================
# ⚠️ IMPORTANTE: No incluir VITE_SUPABASE_ANON_KEY aquí
# Las credenciales deben estar SOLO en el servidor
# Descomentar solo si necesitas acceso directo (no recomendado)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key (NO USAR)
