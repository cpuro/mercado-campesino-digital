# ============================================================
# FRONTEND - Variables de Entorno
# ============================================================
# COPIAR este archivo a .env.local y llenar con valores reales.
# En producción, configurar estas mismas variables en Vercel.

# ============================================================
# SUPABASE (acceso directo)
# ============================================================
# URL del proyecto Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co

# ANON KEY (pública por diseño - segura de exponer en el cliente)
# Supabase → Project Settings → API → Project API keys → "anon public"
# ⚠️ NUNCA usar el SERVICE_ROLE KEY en el frontend.
VITE_SUPABASE_ANON_KEY=your-anon-public-key
