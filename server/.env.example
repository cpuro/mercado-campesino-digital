# ============================================================
# API GATEWAY - Variables de Entorno
# ============================================================
# COPIAR este archivo a .env.local y llenar con valores reales
# NUNCA incluir valores reales en git

# ============================================================
# SERVIDOR
# ============================================================
PORT=3001
NODE_ENV=development

# ============================================================
# SUPABASE
# ============================================================
# URL del proyecto Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co

# SERVICE KEY (Secreto - nunca exponer al cliente)
# Obtener de: Supabase Dashboard → Settings → API → Service Role
SUPABASE_SERVICE_KEY=your-service-key-here

# ============================================================
# CORS & SEGURIDAD
# ============================================================
# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# ============================================================
# JWT
# ============================================================
# Secreto para firmar JWTs (generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-jwt-secret-here

# ============================================================
# DATABASE (Opcional - si usas queries directas)
# ============================================================
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
